# ── AI Platform Configuration ──────────────────────────────
# Copy this to .env and fill in your credentials.
# All fields are optional.
#
# Docker Compose reads this file automatically.

DEBUG=false
LOG_LEVEL=INFO
LOG_JSON=false

# ── OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_ORG_ID=

# ── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Google Gemini ──────────────────────────────────────────
GEMINI_API_KEY=

# ── Ollama (local) ─────────────────────────────────────────
# When running in Docker, use host.docker.internal to reach
# the host machine's Ollama instance.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_DEFAULT_MODEL=llama3

# ── Server ─────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
